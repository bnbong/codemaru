# GitHub token for the GraphQL API (server-only, never exposed to the browser).
# Optional in fixture mode; required once live adapters land.
GITHUB_TOKEN=

# Public base URL used by the generator to build embed snippets.
PUBLIC_BASE_URL=http://localhost:8000

# When true, all endpoints serve deterministic fixture data (no external calls).
FIXTURE_MODE=true

# Cache / adapter tuning (used once live adapters land).
CACHE_TTL_SECONDS=3600
STALE_TTL_SECONDS=86400
ADAPTER_TIMEOUT_SECONDS=3

# Optional external cache for production (not required for the MVP).
REDIS_URL=

# Vercel KV (Upstash Redis) REST credentials for adoption tracking
# (/api/stats/badge). Injected by the Vercel KV integration in prod; leave empty
# locally — tracking just no-ops and the badge reads 0.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Timeout (seconds) for the best-effort KV calls behind adoption tracking.
# Raise it if the KV region is far from the deployment region.
ANALYTICS_TIMEOUT_SECONDS=0.8
