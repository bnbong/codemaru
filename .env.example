# GitHub token for the GraphQL API (server-only, never exposed to the browser).
# Optional in fixture mode; required once live adapters land.
GITHUB_TOKEN=

# Public base URL used by the generator to build embed snippets.
PUBLIC_BASE_URL=http://localhost:8000

# When true, all endpoints serve deterministic fixture data (no external calls).
FIXTURE_MODE=true

# Cache / adapter tuning (used once live adapters land).
CACHE_TTL_SECONDS=3600
STALE_TTL_SECONDS=86400
# Per-request read budget (seconds). GitHub's GraphQL query is heavy for active
# accounts (a single page can take 3-4s); keep this >=8 so such profiles aren't
# dropped to "unavailable". Lower only for testing.
ADAPTER_TIMEOUT_SECONDS=8

# Optional external cache for production (not required for the MVP).
REDIS_URL=

# Vercel KV (Upstash Redis) REST credentials for adoption tracking
# (/api/stats/badge). Injected by the Vercel KV integration in prod; leave empty
# locally — tracking just no-ops and the badge reads 0.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Timeout (seconds) for the best-effort KV calls behind adoption tracking.
# Raise it if the KV region is far from the deployment region.
ANALYTICS_TIMEOUT_SECONDS=0.8

# Shared secret that blocks Cloudflare-proxy bypass via the raw *.vercel.app
# origin. When set, add a Cloudflare *request*-header Transform Rule injecting the
# SAME value as `X-Origin-Auth` on every request; the app then 403s any request
# without it. Set ONLY in production (leave Preview/Dev blank), and deploy the
# Cloudflare rule first or live traffic 403s. Leave empty here to disable.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ORIGIN_SHARED_SECRET=
